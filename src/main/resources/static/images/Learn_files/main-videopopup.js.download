$(document).ready(function () {
    const videoPopup = $("#video_playback_overlay");
    const formPopup = $("#call_back_overlay");
    const mainVideoContainer = document.getElementById("mainVideo");
    const thumbnailRow = document.getElementById("thumbnailRow");

    const videoLinks = [
        "video-popup/videos/anagha_review.mp4",
        "video-popup/videos/amina_review.mp4",
        "video-popup/videos/vinodsir.mp4",
        "video-popup/videos/Networking_courses.mp4"
    ];
    const videoThumbnails = [
        "video-popup/thumbnails/anagha.jpg",
        "video-popup/thumbnails/amina.jpg",
        "video-popup/thumbnails/vinod.jpg",
        "video-popup/thumbnails/networking.jpg"
    ];

    let currentIndex = -1;
    const thumbnails = [];
    let videoAlreadyShown = false; // ensure video popup only shows once

    // Generate thumbnails
    videoLinks.forEach((link, index) => {
        const thumb = document.createElement("img");
        thumb.src = videoThumbnails[index];
        thumb.alt = `Video ${index + 1}`;
        thumb.className = "thumb-img";
        thumbnails.push(thumb);
        thumbnailRow.appendChild(thumb);
        thumb.addEventListener("click", () => {
            currentIndex = index;
            loadVideoPlayer(index, true);
        });
    });

    function highlightThumbnail(index) {
        thumbnails.forEach((thumb, i) => {
            thumb.classList.toggle("active-thumb", i === index);
        });
    }

    function loadVideoPlayer(index, autoplay = false) {
        const link = videoLinks[index];
        mainVideoContainer.innerHTML = "";

        const video = document.createElement("video");
        video.src = link;
        video.controls = true;
        video.style.width = "100%";
        video.style.height = "100%";

        if (autoplay) {
            video.autoplay = true;
            video.muted = false;
        }

        mainVideoContainer.appendChild(video);
        highlightThumbnail(index);
    }

    function playRandomVideo() {
        let randomIndex;
        do {
            randomIndex = Math.floor(Math.random() * videoLinks.length);
        } while (randomIndex === currentIndex && videoLinks.length > 1);

        currentIndex = randomIndex;
        loadVideoPlayer(currentIndex, true);
    }

    function showFormPopupLooping() {
        setTimeout(() => {
            formPopup.fadeIn();
        }, 20000); // 1 seconds after closing
    }

    // Video popup close
    $(".video_close_button_overlay").on("click", function () {
        const currentVideo = mainVideoContainer.querySelector("video");
        if (currentVideo) {
            currentVideo.pause();
            currentVideo.src = "";
            currentVideo.load();
            mainVideoContainer.innerHTML = "";
        }

        videoPopup.fadeOut(() => {
            showFormPopupLooping();
        });
    });

    // Form popup close (continues loop)
    $(".close_button_overlay").on("click", function () {
        formPopup.fadeOut(() => {
            showFormPopupLooping();
        });
    });

    // Autoplay fallback for browser restrictions
    document.addEventListener("click", () => {
        const currentVideo = mainVideoContainer.querySelector("video");
        if (currentVideo && currentVideo.paused) {
            currentVideo.muted = false;
            currentVideo.play().catch(err => console.log("Autoplay blocked:", err));
        }
    }, { once: true });

    // Initial setup
    videoPopup.hide();
    formPopup.hide();

    // Start: show video popup only ONCE
    setTimeout(() => {
        if (!videoAlreadyShown) {
            videoAlreadyShown = true;
            playRandomVideo();
            videoPopup.fadeIn();
        }
    }, 1000); // 1s after page load
});



// end videopopup

  $('#reg_date_of_birth').on('click', function(){
    var today = new Date().toISOString().split('T')[0];
    $(this).attr('max', today);
  });

  $('#back_to_courses').click(function(){
    window.location.href = "courses-scope-india.html";
  });

  $('#batch_time_software').load("batch-time/batch-time-software.data");
  $('#batch_time_networking').load("batch-time/batch-time-networking.data");
  $('#batch_time_others').load("batch-time/batch-time-others.data");

  // if we want to disable right click
  
  // $(document).on('contextmenu', function(e) {
  //   e.preventDefault();
  // });
});

